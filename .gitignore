# app_data (runtime, not in git except .gitkeep structure)
app_data/*
!app_data/.gitkeep
!app_data/workspaces/
app_data/workspaces/*
!app_data/workspaces/.gitkeep
!app_data/ssh/
app_data/ssh/*
!app_data/ssh/.gitkeep

